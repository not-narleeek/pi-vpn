{
	"name": "pi-vpn",
	"version": "0.2.0",
	"description": "OpenVPN for pi — a pi extension plus a standalone, tmux-friendly terminal UI for managing CTF & lab VPN tunnels that survive restarts.",
	"type": "module",
	"keywords": [
		"pi-package",
		"vpn",
		"openvpn",
		"pi",
		"security",
		"ctf",
		"bug-bounty",
		"pentest",
		"automation",
		"ai-agent"
	],
	"license": "MIT",
	"author": "not-narleeek",
	"homepage": "https://github.com/not-narleeek/pi-vpn",
	"repository": {
		"type": "git",
		"url": "https://github.com/not-narleeek/pi-vpn.git"
	},
	"bugs": {
		"url": "https://github.com/not-narleeek/pi-vpn/issues"
	},
	"files": [
		"extensions",
		"tui",
		"bin",
		"dist",
		"docs",
		"README.md",
		"CHANGELOG.md",
		"LICENSE"
	],
	"bin": {
		"pi-vpn": "dist/pi-vpn.cjs"
	},
	"pi": {
		"extensions": [
			"./extensions/vpn.ts"
		]
	},
	"scripts": {
		"clean": "rm -rf node_modules dist",
		"build": "esbuild tui/vpn-tui.ts --bundle --platform=node --format=cjs --outfile=dist/pi-vpn.cjs --log-level=info",
		"check": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.tui.json",
		"prepare": "npm run build"
	},
	"devDependencies": {
		"@types/node": "^22.0.0",
		"esbuild": "^0.25.0",
		"typescript": "^5.6.0"
	},
	"peerDependencies": {
		"@earendil-works/pi-ai": "*",
		"@earendil-works/pi-coding-agent": "*",
		"@earendil-works/pi-tui": "*",
		"typebox": "*"
	},
	"peerDependenciesMeta": {
		"@earendil-works/pi-ai": { "optional": false },
		"@earendil-works/pi-coding-agent": { "optional": false },
		"@earendil-works/pi-tui": { "optional": false },
		"typebox": { "optional": false }
	},
	"engines": {
		"node": ">=18"
	}
}
